FROM ubuntu:18.04

RUN apt update && apt -y full-upgrade && apt -y install \
        git \
        zip \
        curl \
    && apt -y install \
        autoconf \
        automake \
        autotools-dev \
        curl \
        python3 \
        libmpc-dev \
        libmpfr-dev \
        libgmp-dev \
        gawk \
        build-essential \
        bison \
        flex \
        texinfo \
        gperf \
        libtool \
        patchutils \
        bc \
        zlib1g-dev \
        libexpat-dev \
    && apt -y install \
        gcc \
        g++ \
        gperf \
        bison \
        flex \
        texinfo \
        help2man \
        make \
        libncurses5-dev \
        python3-dev \
        autoconf \
        automake \
        libtool \
        libtool-bin \
        gawk \
        wget \
        bzip2 \
        xz-utils \
        unzip \
        patch \
        libstdc++6 \
        rsync \
        meson \
        ninja-build \
        python3-pip \
    && apt -y install \
        dpkg-cross \
        g++-riscv64-linux-gnu \
        gcc-riscv64-linux-gnu \
        mingw-w64 \
        texlive \
    && apt clean && rm -rf /var/lib/apt/lists/*
#NOTE: from Ubuntu 20.04, install `crossbuild-essential-riscv64` instead of dpkg-cross and riscv64 compilers

RUN pip3 install meson

RUN git config --global user.name "John Doe" \
    && git config --global user.email johndoe@example.com
RUN git clone -b crosstool-ng-1.26.0 https://github.com/crosstool-ng/crosstool-ng.git ctng \
    && cd ctng \
    && git cherry-pick a0bf704 b9e57eb 901722d \
    && ./bootstrap \
    && ./configure --prefix=/usr \
    && make -j$(nproc) \
    && make install \
    && cd .. \
    && rm -r ctng

ARG CTNG_UID=1000
ARG CTNG_GID=1000
RUN groupadd -g $CTNG_GID ctng
RUN useradd -d /home/ctng -m -g $CTNG_GID -u $CTNG_UID -s /bin/bash ctng
