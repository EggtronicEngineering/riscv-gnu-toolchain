CT_CONFIG_VERSION="4"
CT_EXPERIMENTAL=y
CT_PREFIX_DIR="${CT_PREFIX}"
# CT_REMOVE_DOCS is not set
CT_BUILD_MANUALS=y
# CT_PREFIX_DIR_RO is not set
CT_ARCH_RISCV=y
CT_MULTILIB=y
CT_DEMULTILIB=y
CT_ARCH_ARCH="rv32imfcxpulpv2"
CT_ARCH_ABI="ilp32f"
CT_BINUTILS_SRC_CUSTOM=y
CT_BINUTILS_CUSTOM_LOCATION="riscv-binutils"
CT_BINUTILS_PATCH_NONE=y
CT_BINUTILS_V_2_34=y
CT_BINUTILS_EXTRA_CONFIG_ARRAY="--disable-libdecnumber --disable-readline"
CT_NEWLIB_SRC_CUSTOM=y
CT_NEWLIB_CUSTOM_LOCATION="riscv-newlib"
CT_NEWLIB_PATCH_NONE=y
CT_NEWLIB_V_4_2=y
CT_LIBC_NEWLIB_TARGET_CFLAGS="-O2 -D_POSIX_MODE"
CT_LIBC_NEWLIB_IO_C99FMT=y
CT_LIBC_NEWLIB_IO_LL=y
CT_LIBC_NEWLIB_IO_FLOAT=y
CT_LIBC_NEWLIB_IO_LDBL=y
CT_LIBC_NEWLIB_REGISTER_FINI=y
# CT_LIBC_NEWLIB_GLOBAL_ATEXIT is not set
# CT_LIBC_NEWLIB_ENABLE_TARGET_OPTSPACE is not set
CT_LIBC_NEWLIB_EXTRA_CONFIG_ARRAY="CXXFLAGS_FOR_TARGET=\"-O2 -D_POSIX_MODE ${CXXFLAGS_FOR_TARGET}\""
# CT_LIBC_PICOLIBC_IO_C99FMT is not set
CT_LIBC_PICOLIBC_GLOBAL_ATEXIT=y
CT_LIBC_PICOLIBC_EXTRA_SECTIONS=y
CT_LIBC_PICOLIBC_EXTRA_CONFIG_ARRAY="-Dsysroot-install=true -Dsysroot-install-skip-checks=true"
CT_GCC_SRC_CUSTOM=y
CT_GCC_CUSTOM_LOCATION="riscv-gcc"
CT_GCC_PATCH_NONE=y
CT_GCC_V_9=y
CT_CC_GCC_CORE_EXTRA_CONFIG_ARRAY="CFLAGS_FOR_TARGET=\"-Os ${CFLAGS_FOR_TARGET}\" CXXFLAGS_FOR_TARGET=\"-Os ${CXXFLAGS_FOR_TARGET}\""
CT_CC_GCC_EXTRA_CONFIG_ARRAY="CFLAGS_FOR_TARGET=\"-Os ${CFLAGS_FOR_TARGET}\" CXXFLAGS_FOR_TARGET=\"-Os ${CXXFLAGS_FOR_TARGET}\""
CT_CC_GCC_MULTILIB_GENERATOR="rv32imfcxpulpv2-ilp32f-- rv32imc_zfinx_xpulpv2-ilp32-- rv32imcxpulpv2-ilp32-- rv32imfc-ilp32f-- rv32imc-ilp32--"
CT_CC_GCC_SYSTEM_ZLIB=y
# CT_CC_GCC_LDBL_128 is not set
CT_CC_LANG_CXX=y
CT_DEBUG_GDB=y
CT_GDB_SRC_CUSTOM=y
CT_GDB_CUSTOM_LOCATION="riscv-gdb"
CT_GDB_PATCH_NONE=y
CT_GDB_V_9=y
CT_GDB_CROSS_STATIC=y
CT_GDB_CROSS_SIM=y
CT_COMP_LIBS_NEWLIB_NANO=y
CT_NEWLIB_NANO_SRC_CUSTOM=y
CT_NEWLIB_NANO_CUSTOM_LOCATION="riscv-newlib"
CT_NEWLIB_NANO_PATCH_NONE=y
CT_NEWLIB_NANO_V_4_2=y
CT_NEWLIB_NANO_INSTALL_IN_TARGET=y
CT_LIBC_NEWLIB_NANO_IO_FLOAT=y
# CT_LIBC_NEWLIB_NANO_FVWRITE_IN_STREAMIO is not set
CT_LIBC_NEWLIB_NANO_DISABLE_SUPPLIED_SYSCALLS=y
CT_LIBC_NEWLIB_NANO_EXTRA_SECTIONS=y
CT_COMP_LIBS_PICOLIBC=y
CT_ZSTD_NEEDED=y
